# ============================================================================
# Domain
# ============================================================================

# Production domain (used by Traefik for routing and TLS certificates)
DOMAIN=localhost

# Backend uses this to generate frontend links (emails, redirects, etc.)
FRONTEND_HOST=http://localhost:3000

# Available values: local | staging | production
ENVIRONMENT=local

PROJECT_NAME=your-project-name
STACK_NAME=your-stack-name

# ============================================================================
# Backend
# ============================================================================

BACKEND_CORS_ORIGINS="http://localhost,http://localhost:3000,https://localhost,https://localhost:3000"

SECRET_KEY=your-secret-key

FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=change-me

# ============================================================================
# Email
# ============================================================================

SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=

EMAILS_FROM_EMAIL=noreply@example.com

SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# ============================================================================
# Database
# ============================================================================

POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# ============================================================================
# Monitoring
# ============================================================================

SENTRY_DSN=

# ============================================================================
# Docker Images
# ============================================================================

DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
